# 支持 OpenAI 的 DeepSeek API
DEEPSEEK_API_KEY=""
DEEPSEEK_API_BASE=""
DEEPSEEK_API_MODEL=""

# PostgreSQL / Supabase
# 务必从 Dashboard → Connect → Session pooler 复制 URI，不要手拼 aws-0/aws-1 或端口
#
# PaaS 仅 IPv4 时（DigitalOcean 等）：应用与 migration 均使用 Session pooler（5432）
#   DATABASE_URL = Session pooler（用户名 postgres.[ref]，host 为 *.pooler.supabase.com:5432）
# 若有 IPv6 直连，migration 可单独用 Direct connection（可选）：
#   DATABASE_MIGRATE_URL = db.[project-ref].supabase.co:5432
# 若只配 DATABASE_URL，migration 会自动使用同一条 Session pooler 连接
#
# Session pooler 示例（port 5432；6543 是 Transaction pooler，不要用）：
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require"
#
# Direct connection 示例（可选，仅 migration）：
# DATABASE_MIGRATE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require"
#
# 密码含 / @ # 等须 URL 编码（/ → %2F）；或在 Supabase 重置为无特殊字符的密码
DATABASE_URL=""
DATABASE_MIGRATE_URL=""

# JWT
JWT_SECRET=""
JWT_ACCESS_TTL="168h"

# Redis Cloud（skip_verify=false 时必需）
REDIS_URL=""

# Resend 邮件
RESEND_API_KEY=""
RESEND_FROM="FreeStyleTarot <verify@freestyletarot.fun>"

# 前端 Origin（CORS）
CORS_ORIGIN="http://localhost:5173"
